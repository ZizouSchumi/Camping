# Godot 4.x — gestion des fins de ligne et binaires

# Texte Godot — normaliser en LF
*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.godot text eol=lf
*.gdshader text eol=lf
*.gdshaderinc text eol=lf

# Config
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Markdown / docs
*.md text eol=lf

# Binaires — ne pas modifier
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg binary
*.wav binary
*.ogg binary
*.mp3 binary
*.mp4 binary
*.import binary
*.glb binary
*.gltf text eol=lf
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
