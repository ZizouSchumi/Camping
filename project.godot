; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Camping"
run/main_scene="res://scenes/world/world.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoloads/event_bus.gd"
GameData="*res://autoloads/game_data.gd"
GridSystem="*res://autoloads/grid_system.gd"
SaveSystem="*res://autoloads/save_system.gd"
NeedsSystem="*res://autoloads/needs_system.gd"
SeasonManager="*res://autoloads/season_manager.gd"
UIManager="*res://autoloads/ui_manager.gd"
PlatformManager="*res://autoloads/platform_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

