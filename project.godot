; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format allows you to do so.

config_version=5

[application]

config/name="Camping"
config/features=PackedStringArray("4.3", "Mobile")
run/main_scene="res://scenes/world/world.tscn"
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoloads/event_bus.gd"
GameData="*res://autoloads/game_data.gd"
GridSystem="*res://autoloads/grid_system.gd"
SaveSystem="*res://autoloads/save_system.gd"
NeedsSystem="*res://autoloads/needs_system.gd"
SeasonManager="*res://autoloads/season_manager.gd"
UIManager="*res://autoloads/ui_manager.gd"
PlatformManager="*res://autoloads/platform_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/resizable=true
window/stretch/mode="canvas_items"

